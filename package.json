{
  "name": "obsidra-tradebot",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "pnpm db:generate && pnpm -r build",
    "dev": "pnpm --parallel --filter @obsidra/engine --filter @obsidra/api --filter @obsidra/dashboard dev",
    "start": "node scripts/start-production.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @obsidra/shared build && pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @obsidra/shared prisma:generate",
    "db:push": "pnpm --filter @obsidra/shared prisma:push",
    "db:migrate": "pnpm --filter @obsidra/shared prisma:migrate",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "audit:prod": "pnpm audit --prod --audit-level high"
  },
  "devDependencies": {
    "@obsidra/shared": "workspace:*",
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
