generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id               String    @id @default(cuid())
  bybitOrderId     String    @unique
  symbol           String
  direction        String
  status           String
  entryPrice       Float?
  exitPrice        Float?
  stopLoss         Float
  takeProfit       Float
  positionSizeUsdt Float
  leverage         Int
  pnlUsdt          Float?
  pnlPct           Float?
  feeUsdt          Float?
  slippage         Float?
  holdTimeSeconds  Int?
  signalScore      Int
  signalData       Json
  mlScore          Float?
  marketRegime     String?
  openedAt         DateTime?
  closedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model DailyMetrics {
  id         String   @id @default(cuid())
  date       String   @unique
  pnlUsdt    Float    @default(0)
  tradeCount Int      @default(0)
  winCount   Int      @default(0)
  feesUsdt   Float    @default(0)
  equityEnd  Float
  createdAt  DateTime @default(now())
}

model MlWeights {
  id         String   @id @default(cuid())
  weights    Json
  trainedAt  DateTime @default(now())
  tradeCount Int
}

model AdaptiveLog {
  id        String   @id @default(cuid())
  regime    String
  config    Json
  reason    String
  createdAt DateTime @default(now())
}

model BotEvent {
  id        String   @id @default(cuid())
  type      String
  message   String
  data      Json?
  createdAt DateTime @default(now())
}
