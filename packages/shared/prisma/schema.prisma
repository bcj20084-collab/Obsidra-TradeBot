generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id               String    @id @default(cuid())
  clientOrderId    String    @unique
  bybitOrderId     String?   @unique
  symbol           String
  direction        String
  status           String
  entryPrice       Float?
  exitPrice        Float?
  stopLoss         Float
  takeProfit       Float
  positionSizeUsdt Float
  leverage         Int
  pnlUsdt          Float?
  pnlPct           Float?
  feeUsdt          Float?
  slippage         Float?
  holdTimeSeconds  Int?
  signalScore      Int
  signalData       Json
  mlScore          Float?
  marketRegime     String?
  closeReason      String?
  openedAt         DateTime?
  closedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  transitions      OrderTransition[]
  journalEntries   JournalEntry[]

  @@index([status, symbol])
  @@index([closedAt])
}

model OrderTransition {
  id        String   @id @default(cuid())
  tradeId   String
  fromState String?
  toState   String
  reason    String
  data      Json?
  createdAt DateTime @default(now())
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId, createdAt])
}

model JournalEntry {
  id        String   @id @default(cuid())
  tradeId   String?
  type      String
  data      Json
  createdAt DateTime @default(now())
  trade     Trade?   @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
}

model DailyMetrics {
  id         String   @id @default(cuid())
  date       String
  symbol     String   @default("ALL")
  pnlUsdt    Float    @default(0)
  tradeCount Int      @default(0)
  winCount   Int      @default(0)
  feesUsdt   Float    @default(0)
  equityEnd  Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, symbol])
}

model HistoricalCandle {
  id       String @id @default(cuid())
  symbol   String
  interval String
  openTime BigInt
  open     Float
  high     Float
  low      Float
  close    Float
  volume   Float
  turnover Float

  @@unique([symbol, interval, openTime])
  @@index([symbol, interval, openTime])
}

model MlWeights {
  id         String   @id @default(cuid())
  weights    Json
  symbol     String   @default("ALL")
  bias       Float    @default(0)
  cvAccuracy Float?
  cvLogLoss  Float?
  wfEfficiency Float?
  trainedAt  DateTime @default(now())
  tradeCount Int
}

model MlTrainingLog {
  id                String   @id @default(cuid())
  symbol            String
  tradeCount        Int
  cvAccuracy        Float
  cvLogLoss         Float
  wfEfficiency      Float
  featureImportance Json
  savedWeights      Boolean
  rejectReason      String?
  trainedAt         DateTime @default(now())
}

model AdaptiveLog {
  id        String   @id @default(cuid())
  regime    String
  symbol    String   @default("ALL")
  config    Json
  reason    String
  createdAt DateTime @default(now())
}

model BacktestResult {
  id          String   @id @default(cuid())
  symbol      String
  startDate   String
  endDate     String
  config      Json
  metrics     Json
  equityCurve Json
  trades      Json
  createdAt   DateTime @default(now())

  @@index([symbol, createdAt])
}

model BotEvent {
  id        String   @id @default(cuid())
  type      String
  symbol    String?
  message   String
  data      Json?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  actor     String
  details   Json
  ipAddress String?
  createdAt DateTime @default(now())
}

model BotState {
  id        String   @id @default("singleton")
  status    String   @default("STOPPED")
  reason    String?
  updatedAt DateTime @updatedAt
}
